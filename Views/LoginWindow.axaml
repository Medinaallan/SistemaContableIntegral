<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaComunidad.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="SistemaComunidad.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Iniciar Sesión - Sistema Comunitario"
        Width="500" Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Width="400"
                    Spacing="20">

            <!-- Encabezado -->
            <Border Background="#2196F3" 
                    Padding="30,25" 
                    CornerRadius="10"
                    BoxShadow="0 4 8 0 #40000000">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sistema Contable Integral" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <TextBlock Text="Gestión Contable para Patronatos e Iglesias" 
                               FontSize="14" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Opacity="0.9"/>
                </StackPanel>
            </Border>

            <!-- Formulario de Login -->
            <Border Background="White" 
                    Padding="35,30" 
                    CornerRadius="10"
                    BoxShadow="0 2 10 0 #20000000">
                <StackPanel Spacing="20">
                    
                    <TextBlock Text="Iniciar Sesión" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="#333333"/>

                    <!-- Usuario -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Usuario:" 
                                   FontSize="13"
                                   Foreground="#555555"/>
                        <TextBox Text="{Binding NombreUsuario}" 
                                 Watermark="Ingrese su usuario"
                                 FontSize="14"
                                 Padding="12,10"
                                 CornerRadius="5"
                                 BorderThickness="1"
                                 BorderBrush="#CCCCCC"/>
                    </StackPanel>

                    <!-- Contraseña -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Contraseña:" 
                                   FontSize="13"
                                   Foreground="#555555"/>
                        <TextBox Text="{Binding Password}" 
                                 Watermark="Ingrese su contraseña"
                                 PasswordChar="●"
                                 FontSize="13"
                                 Padding="12,10"
                                 CornerRadius="5"
                                 BorderThickness="1"
                                 BorderBrush="#CCCCCC"/>
                    </StackPanel>

                    <!-- Mensaje de Error -->
                    <Border IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="#FFEBEE"
                            Padding="12"
                            CornerRadius="5"
                            BorderThickness="1"
                            BorderBrush="#EF5350">
                        <TextBlock Text="{Binding MensajeError}" 
                                   Foreground="#C62828"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Botón de Login -->
                    <Button Command="{Binding IniciarSesionCommand}"
                            IsEnabled="{Binding !EstaAutenticando}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="0,12"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Background="#2196F3"
                            Foreground="White"
                            CornerRadius="5"
                            Cursor="Hand">
                        <Panel>
                            <TextBlock Text="Iniciar Sesión" 
                                       IsVisible="{Binding !EstaAutenticando}"/>
                            <TextBlock Text="Autenticando..." 
                                       IsVisible="{Binding EstaAutenticando}"/>
                        </Panel>
                    </Button>

                    <!-- Información de credenciales -->
                    <Border Background="#E3F2FD" 
                            Padding="12"
                            CornerRadius="5"
                            Margin="0,10,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Credenciales por defecto:" 
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#1976D2"/>
                            <TextBlock FontSize="11" Foreground="#424242">
                                <Run Text="Usuario:"/>
                                <Run Text="admin" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="#424242">
                                <Run Text="Contraseña:"/>
                                <Run Text="admin123" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- Versión -->
            <TextBlock Text="Versión 1.0.0" 
                       FontSize="11" 
                       Foreground="#999999"
                       HorizontalAlignment="Center"/>

        </StackPanel>
    </Grid>

</Window>
