<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaComunidad.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="SistemaComunidad.Views.AportesWindow"
        x:Name="Root"
        x:DataType="vm:AportesViewModel"
        Title="Aportes y Donaciones"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Background="#F5F5F5">

    <Design.DataContext>
        <vm:AportesViewModel/>
    </Design.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <TextBlock Text="Aportes y Donaciones" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Formulario registro -->
            <Border Background="White" Padding="15" CornerRadius="6" Margin="0,0,10,0" BoxShadow="0 2 8 0 #15000000">
                <StackPanel Spacing="10">
                    <TextBlock Text="Registrar Aporte/Donación" FontSize="16" FontWeight="SemiBold"/>

                    <TextBlock Text="Persona" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding Personas}" SelectedItem="{Binding PersonaSeleccionada}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Nombres}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding Apellidos}" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Monto" FontSize="12"/>
                    <TextBox Text="{Binding Monto}"/>

                    <TextBlock Text="Concepto" FontSize="12"/>
                    <TextBox Text="{Binding Concepto}"/>

                    <TextBlock Text="Tipo" FontSize="12"/>
                    <ComboBox SelectedItem="{Binding TipoAporte}" ItemsSource="{Binding TiposAporte}" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Registrar" Command="{Binding RegistrarAporteCommand}" Background="#4CAF50" Foreground="White" Padding="10"/>
                        <Button Content="Cargar Aportes" Command="{Binding CargarAportesCommand}" Padding="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lista de aportes -->
            <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="6" BoxShadow="0 2 8 0 #15000000">
                <StackPanel Spacing="10">
                    <TextBlock Text="Aportes recientes" FontSize="16" FontWeight="SemiBold"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Aportes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,0,0,10" Background="#FAFAFA" CornerRadius="4" BorderBrush="#EEE" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Concepto}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FechaAporte, StringFormat={}{0:dd/MM/yyyy HH:mm}}" FontSize="12" Foreground="#666"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding Monto, StringFormat=\L.{0:N2}}" FontSize="14" FontWeight="Bold" Foreground="#4CAF50"/>
                                                <Button Content="Imprimir" Command="{Binding DataContext.ImprimirAporteCommand, ElementName=Root}" CommandParameter="{Binding}" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>