<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaComunidad.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SistemaComunidad.Views.ServiciosWindow"
        x:DataType="vm:ServiciosViewModel"
        Title="Gestión de Servicios del Patronato"
        Width="1100" Height="750"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True"
        Background="#F5F5F5">

    <Design.DataContext>
        <vm:ServiciosViewModel/>
    </Design.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" 
                Background="#9C27B0" 
                Padding="30,25">
            <StackPanel>
                <TextBlock Text="Gestión de Servicios" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Administre los servicios para los pagos mensuales de los socios del patronato" 
                           FontSize="14" 
                           Foreground="White"
                           Opacity="0.9"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel Izquierdo - Formulario -->
            <Border Grid.Column="0" 
                    Background="White" 
                    Padding="25" 
                    CornerRadius="8"
                    BoxShadow="0 2 8 0 #15000000"
                    Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock FontSize="20" 
                                   FontWeight="SemiBold"
                                   Foreground="#333333">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}">
                                    <Binding Path="EsEdicion"/>
                                </MultiBinding>
                            </TextBlock.Text>
                            <TextBlock.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="Text" Value="Nuevo Servicio"/>
                                </Style>
                                <Style Selector="TextBlock[Text='True']">
                                    <Setter Property="Text" Value="Editar Servicio"/>
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>

                        <!-- Mensaje -->
                        <Border IsVisible="{Binding Mensaje, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#66BB6A"/>
                                </Style>
                                <Style Selector="Border[IsVisible=True]">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="#66BB6A"/>
                                </Style>
                            </Border.Styles>
                            <Border BorderThickness="1"
                                    Padding="12"
                                    CornerRadius="5">
                                <TextBlock Text="{Binding Mensaje}" 
                                           Foreground="#2E7D32"
                                           TextWrapping="Wrap"
                                           FontSize="13"/>
                            </Border>
                        </Border>

                        <!-- Nombre del Servicio -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Nombre del Servicio *" 
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="#555555"/>
                            <TextBox Text="{Binding Nombre}" 
                                     Watermark="Ej: Agua Potable, Mantenimiento, Seguridad"
                                     FontSize="14"
                                     Padding="10"/>
                        </StackPanel>

                        <!-- Descripción -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Descripción" 
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="#555555"/>
                            <TextBox Text="{Binding Descripcion}" 
                                     Watermark="Descripción detallada del servicio"
                                     FontSize="14"
                                     Padding="10"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </StackPanel>

                        <!-- Costo Mensual y Periodicidad -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <!-- Costo Mensual -->
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Costo Mensual (L.) *" 
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="#555555"/>
                                <NumericUpDown Value="{Binding CostoMensual}" 
                                               Minimum="0"
                                               Maximum="999999"
                                               FormatString="N2"
                                               FontSize="14"
                                               Padding="10"/>
                            </StackPanel>

                            <!-- Periodicidad -->
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Periodicidad *" 
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="#555555"/>
                                <ComboBox ItemsSource="{Binding Periodicidades}"
                                          SelectedItem="{Binding PeriodicidadSeleccionada}"
                                          HorizontalAlignment="Stretch"
                                          FontSize="14"
                                          Padding="10"/>
                            </StackPanel>
                        </Grid>

                        <!-- Servicio Obligatorio -->
                        <CheckBox IsChecked="{Binding EsObligatorio}"
                                  Content="Servicio obligatorio para todos los socios"
                                  FontSize="13"
                                  Margin="0,5,0,0"/>

                        <!-- Notas -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Notas Adicionales" 
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="#555555"/>
                            <TextBox Text="{Binding Notas}" 
                                     Watermark="Notas o comentarios adicionales"
                                     FontSize="14"
                                     Padding="10"
                                     Height="70"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </StackPanel>

                        <!-- Botones de Acción -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                            <Button Grid.Column="0"
                                    Content="Guardar"
                                    Command="{Binding GuardarCommand}"
                                    Background="#9C27B0"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Padding="15"
                                    CornerRadius="5"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#7B1FA2"/>
                                    </Style>
                                </Button.Styles>
                            </Button>

                            <Button Grid.Column="1"
                                    Content="Cancelar"
                                    Command="{Binding CancelarCommand}"
                                    Background="#E0E0E0"
                                    Foreground="#555555"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Padding="15"
                                    CornerRadius="5"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Panel Derecho - Lista de Servicios -->
            <Border Grid.Column="1" 
                    Background="White" 
                    Padding="20" 
                    CornerRadius="8"
                    BoxShadow="0 2 8 0 #15000000"
                    Margin="10,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" 
                               Text="Servicios Activos" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Servicios}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" 
                                            BorderBrush="#E0E0E0" 
                                            BorderThickness="1"
                                            Padding="15" 
                                            Margin="0,0,0,12"
                                            CornerRadius="6">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                            <!-- Nombre -->
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Nombre}" 
                                                       FontSize="15" 
                                                       FontWeight="SemiBold"
                                                       Foreground="#9C27B0"
                                                       TextWrapping="Wrap"/>

                                            <!-- Descripción -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Descripcion}" 
                                                       FontSize="12" 
                                                       Foreground="#666666"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"
                                                       IsVisible="{Binding Descripcion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                            <!-- Costo y Periodicidad -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="0,8,0,0">
                                                <TextBlock Text="L." 
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="#4CAF50"/>
                                                <TextBlock Text="{Binding CostoMensual, StringFormat='{}{0:N2}'}" 
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="#4CAF50"/>
                                                <TextBlock Text="•" 
                                                           FontSize="13"
                                                           Foreground="#999999"
                                                           Margin="3,0"/>
                                                <TextBlock Text="{Binding Periodicidad}" 
                                                           FontSize="12"
                                                           Foreground="#666666"/>
                                                <TextBlock Text="•" 
                                                           FontSize="13"
                                                           Foreground="#999999"
                                                           Margin="3,0"/>
                                            </StackPanel>

                                            <!-- Botones -->
                                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" Margin="0,10,0,0">
                                                <Button Content="Editar"
                                                        Command="{Binding $parent[ItemsControl].((vm:ServiciosViewModel)DataContext).EditarServicioCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#2196F3"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        CornerRadius="4">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Background" Value="#1976D2"/>
                                                        </Style>
                                                    </Button.Styles>
                                                </Button>

                                                <Button Content="Desactivar"
                                                        Command="{Binding $parent[ItemsControl].((vm:ServiciosViewModel)DataContext).DesactivarCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#FF9800"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        CornerRadius="4"
                                                        IsVisible="{Binding Activo}">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Style>
                                                    </Button.Styles>
                                                </Button>

                                                <Button Content="Activar"
                                                        Command="{Binding $parent[ItemsControl].((vm:ServiciosViewModel)DataContext).ActivarCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#4CAF50"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        CornerRadius="4"
                                                        IsVisible="{Binding !Activo}">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Style>
                                                    </Button.Styles>
                                                </Button>

                                                <Button Content="Eliminar"
                                                        Command="{Binding $parent[ItemsControl].((vm:ServiciosViewModel)DataContext).EliminarCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#F44336"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        CornerRadius="4">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Background" Value="#D32F2F"/>
                                                        </Style>
                                                    </Button.Styles>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
