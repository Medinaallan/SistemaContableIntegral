<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SistemaComunidad.App"
             xmlns:local="using:SistemaComunidad"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        
        <!-- ESTILOS GLOBALES - Deben ir DESPUÉS de FluentTheme para sobrescribirlo -->
        
        <!-- Forzar cursor de mano en todos los botones -->
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- CRÍTICO: Forzar texto blanco en hover en TODOS los botones -->
        <Style Selector="Button:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Atacar el ContentPresenter interno del template -->
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding $parent[Button].Background}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Forzar en TextBlock dentro del ContentPresenter -->
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter > TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Para botones con ContentPresenter directo -->
        <Style Selector="Button:pointerover > ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button:pointerover > ContentPresenter > TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Para cuando el texto está directamente en el botón -->
        <Style Selector="Button:pointerover > TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Estado pressed también debe mantener blanco -->
        <Style Selector="Button:pressed">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button:pressed > ContentPresenter > TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- TabItems deben tener texto oscuro/azul, NO blanco -->
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>
        
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#1976D2"/>
        </Style>
        
        <Style Selector="TabItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E3F2FD"/>
        </Style>
        
        <Style Selector="TabItem:pointerover > ContentPresenter > TextBlock">
            <Setter Property="Foreground" Value="#1976D2"/>
        </Style>
        
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Forzar texto oscuro por defecto en controles de contenido y entradas -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>
        <Style Selector="TextBox:focused">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

        <Style Selector="ContentPresenter">
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

    </Application.Styles>
</Application>